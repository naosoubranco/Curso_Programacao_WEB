algoritmo "O Sistema de Login"
// Disciplina  :  [Linguagem e Lógica de Programação]
// Professor   : [Nome do Professor]

var
usu: caractere
senha:caractere

inicio
    escreva("Usuário: ")
    leia(usu)
    escreva("Senha:")
    leia(senha)
        se usu <- "admin"


        fimse

        


fimalgoritmo